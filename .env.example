# ═══════════════════════════════════════════════════════════════
# Two `.env` files exist in this workflow. This template documents
# BOTH. Read the headers carefully before copying values.
#
#   1. LOCAL .env (on your workstation, loaded by your shell or
#      Claude Code before running Python scripts like
#      generate-image.py or generate-podcast.py).
#
#   2. SERVER .env (uploaded via SFTP to your site root, loaded
#      by PHP via api/_env.php for proxies like brevo.php).
#
# These two files should NEVER be merged and NEVER be committed.
# ═══════════════════════════════════════════════════════════════


# ─── LOCAL .env (workstation only — never uploaded) ─────────
# Load before running scripts/ Python files. Example:
#   export $(grep -v '^#' .env.local | xargs)
# or use direnv, or `source`.

# Gemini API — used by scripts/generate-image.py and scripts/generate-podcast.py
GEMINI_API_KEY=

# Model overrides (optional — leave blank for defaults)
GEMINI_IMAGE_MODEL=
GEMINI_TEXT_MODEL=
GEMINI_TTS_MODEL=
GEMINI_TTS_VOICE_A=
GEMINI_TTS_VOICE_B=


# ─── SERVER .env (SFTP-uploaded to site root) ───────────────
# Created manually on the host via SFTP at the same level as index.html.
# Verify that https://yourdomain.com/.env returns HTTP 403.

# Site URLs — also used by PHP APIs for CORS Allow-Origin
SITE_URL=https://example.com
STAGING_URL=https://staging.example.com

# Brevo — required if the brevo module is active
BREVO_API_KEY=
BREVO_LIST_DEFAULT=

# Mailchimp — required if the mailchimp module is active instead of Brevo
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=


# ─── BOTH (public values, used wherever) ────────────────────
# These are not secrets. They're in .env for convenience but could
# just as well be hardcoded in HTML.

CAL_USERNAME=
CAL_EVENT_SLUG=15min
GA4_MEASUREMENT_ID=
PLAUSIBLE_DOMAIN=
UMAMI_HOST=
UMAMI_WEBSITE_ID=


# ─── GITHUB ACTIONS SECRETS (NEVER in .env) ─────────────────
# Set via `gh secret set NAME`. Listed for reference only:
#   OVH_HOST
#   OVH_USERNAME
#   OVH_PASSWORD
#   OVH_PROD_DIR                 # e.g. /www/
#   OVH_STAGING_DIR              # e.g. /www/staging/
#   OVH_STAGING_HTPASSWD_PATH    # absolute server path to .htpasswd
#   STAGING_HTPASSWD_USER        # staging basic auth username
#   STAGING_HTPASSWD_PASS        # staging basic auth password
